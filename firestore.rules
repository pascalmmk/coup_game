rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Match the games collection
    match /games/{gameId} {
      // 1. You must be authenticated to read or write any game
      allow read: if request.auth != null;
      
      // 2. You can create a new game if you are authenticated
      // Ensure the 'id' field matches the document gameId
      allow create: if request.auth != null 
                    && request.resource.data.id == gameId;
      
      // 3. You can update an existing game if you are authenticated
      allow update: if request.auth != null 
                    && request.resource.data.id == gameId;
                    
      // 4. Do not allow users to delete game documents entirely to prevent griefing
      allow delete: if false;
    }
    
    // Deny access to any other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
